// Denial Management System - Full RCM Schema
// Covers: denials, analyses, appeals, audit logs, users/roles, payer rules,
// notes, financial tracking, and claim scrubbing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTHENTICATION ────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String
  role           String    @default("biller") // admin, manager, biller, coder, client
  department     String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  auditLogs      AuditLog[]
  notes          DenialNote[]
  appeals        AppealLetter[]
  assignments    DenialAssignment[]
  sessions       Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── DENIALS ────────────────────────────────────────────────────────────────────

model Denial {
  id                  String   @id @default(cuid())
  claimNumber         String   @unique
  patientName         String
  patientDOB          String
  patientMemberId     String?
  payerName           String
  payerId             String
  providerNPI         String
  providerName        String?
  facilityName        String?
  dateOfService       String
  denialDate          String
  cptCode             String
  cdtCode             String?
  codeType            String   @default("CPT")  // CPT or CDT
  practiceType        String   @default("medical")  // medical or dental
  modifier            String?
  diagnosisCode       String
  diagnosisCode2      String?
  diagnosisCode3      String?
  diagnosisCode4      String?
  billedAmount        Float
  deniedAmount        Float
  allowedAmount       Float?
  paidAmount          Float?
  carcCode            String
  rarcCode            String?
  adjustmentGroupCode String
  denialCategory      String   @default("other")
  status              String   @default("New") // New, Analyzed, Corrected, Reviewed, Resubmitted, Appealed, Closed
  priority            String   @default("normal") // low, normal, high, critical
  filingDeadline      DateTime?
  filingDeadlineDays  Int?
  isTimelyFilingRisk  Boolean  @default(false)
  batchId             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  analysis       DenialAnalysis?
  correction     CorrectionSuggestion?
  qualityCheck   QualityCheck?
  appeals        AppealLetter[]
  notes          DenialNote[]
  auditLogs      AuditLog[]
  assignments    DenialAssignment[]
  financials     FinancialTracking[]
  scrubResults   ClaimScrubResult[]
  agentTasks     AgentTask[]
}

model DenialAnalysis {
  id                    String   @id @default(cuid())
  denialId              String   @unique
  denialSummary         String
  rootCauseCategory     String
  rootCauseDetail       String
  denialCategory        String
  preventable           Boolean  @default(true)
  correctable           Boolean  @default(true)
  appealRecommended     Boolean  @default(false)
  confidenceScore       Float    @default(0.5)
  recommendedNextAction String
  requiredInformation   String   @default("[]") // JSON array
  complianceNotes       String   @default("[]") // JSON array
  analyzedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  denial Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
}

model CorrectionSuggestion {
  id                      String   @id @default(cuid())
  denialId                String   @unique
  correctionType          String
  correctionSummary       String
  correctionRationale     String
  proposedChanges         String   @default("[]") // JSON array
  requiredDocuments       String   @default("[]") // JSON array
  resubmissionInstructions String  @default("{}") // JSON object
  confidenceScore         Float    @default(0.5)
  riskLevel               String   @default("medium") // low, medium, high
  complianceNotes         String   @default("[]") // JSON array
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  denial Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
}

model QualityCheck {
  id                String   @id @default(cuid())
  denialId          String   @unique
  overallResult     String   @default("warning") // pass, fail, warning
  validationFindings String  @default("[]") // JSON array
  blockingIssues    String   @default("[]") // JSON array
  warnings          String   @default("[]") // JSON array
  recommendation    String   @default("request_more_info")
  confidenceScore   Float    @default(0.5)
  checkedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  denial Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
}

// ─── APPEAL LETTERS ─────────────────────────────────────────────────────────────

model AppealLetter {
  id              String   @id @default(cuid())
  denialId        String
  appealType      String   @default("first_level") // first_level, second_level, external_review
  status          String   @default("draft") // draft, pending_review, sent, accepted, denied, expired
  letterContent   String   // Full appeal letter text (markdown)
  supportingDocs  String   @default("[]") // JSON array of document references
  recipientName   String?
  recipientFax    String?
  recipientAddress String?
  sentAt          DateTime?
  responseDate    DateTime?
  responseNotes   String?
  deadline        DateTime?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  denial    Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([denialId])
  @@index([status])
}

// ─── NOTES & COMMENTS ───────────────────────────────────────────────────────────

model DenialNote {
  id        String   @id @default(cuid())
  denialId  String
  authorId  String
  content   String
  noteType  String   @default("general") // general, internal, escalation, payer_contact, resolution
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  denial Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([denialId])
}

// ─── AUDIT TRAIL ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  denialId    String?
  action      String   // create, update, delete, view, analyze, correct, appeal, export, login, logout
  entityType  String   // denial, appeal, note, user, payer_rule, report
  entityId    String?
  oldValues   String?  // JSON of previous values
  newValues   String?  // JSON of new values
  ipAddress   String?
  userAgent   String?
  metadata    String?  // JSON additional context
  createdAt   DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  denial Denial? @relation(fields: [denialId], references: [id])

  @@index([userId])
  @@index([denialId])
  @@index([action])
  @@index([createdAt])
}

// ─── PAYER RULES ENGINE ─────────────────────────────────────────────────────────

model PayerRule {
  id                  String   @id @default(cuid())
  payerName           String
  payerId             String?
  ruleType            String   // filing_deadline, auth_required, modifier_rules, bundling, documentation
  ruleName            String
  description         String?
  conditions          String   @default("{}") // JSON conditions (cptCode patterns, diagnosis patterns, etc.)
  filingDeadlineDays  Int?     // Days from DOS or denial date for timely filing
  appealDeadlineDays  Int?     // Days allowed for appeal submission
  requiresAuth        Boolean  @default(false)
  contactPhone        String?
  contactFax          String?
  contactEmail        String?
  contactAddress      String?
  portalUrl           String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([payerName])
  @@index([ruleType])
}

// ─── FINANCIAL TRACKING ─────────────────────────────────────────────────────────

model FinancialTracking {
  id                String   @id @default(cuid())
  denialId          String
  eventType         String   // resubmission, partial_payment, full_payment, write_off, adjustment, refund
  amount            Float
  checkNumber       String?
  eraTraceNumber    String?
  paymentDate       DateTime?
  postingDate       DateTime?
  notes             String?
  createdAt         DateTime @default(now())

  denial Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)

  @@index([denialId])
  @@index([eventType])
}

// ─── DENIAL ASSIGNMENT / WORKLIST ───────────────────────────────────────────────

model DenialAssignment {
  id          String    @id @default(cuid())
  denialId    String
  assignedTo  String
  assignedBy  String?
  status      String    @default("active") // active, completed, reassigned
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  denial     Denial @relation(fields: [denialId], references: [id], onDelete: Cascade)
  assignee   User   @relation(fields: [assignedTo], references: [id])

  @@index([denialId])
  @@index([assignedTo])
}

// ─── CLAIM SCRUBBING / DENIAL PREVENTION ────────────────────────────────────────

model ClaimScrubRule {
  id          String   @id @default(cuid())
  ruleName    String
  ruleType    String   // coding_validation, modifier_check, diagnosis_match, auth_required, ncd_lcd, bundling
  description String?
  conditions  String   @default("{}") // JSON: CPT ranges, diagnosis codes, payer patterns
  action      String   @default("warn") // warn, block, auto_correct
  severity    String   @default("medium") // low, medium, high, critical
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClaimScrubResult {
  id          String   @id @default(cuid())
  denialId    String?  // Can be linked to a denial for prevention tracking
  claimNumber String?
  ruleId      String?
  ruleName    String
  ruleType    String
  severity    String   @default("medium")
  finding     String   // What was found
  suggestion  String?  // How to fix it
  status      String   @default("open") // open, resolved, ignored
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  denial Denial? @relation(fields: [denialId], references: [id])

  @@index([denialId])
  @@index([status])
}

// ─── OVERVIEW REPORTS ───────────────────────────────────────────────────────────

model OverviewReport {
  id                  String   @id @default(cuid())
  fileName            String
  uploadDate          DateTime @default(now())
  totalClaims         Int
  totalDeniedAmount   Float
  overallRating       Float
  ratingLabel         String
  ratingColor         String
  executiveSummary    String
  keyIssues           String   @default("[]") // JSON array
  categoryBreakdown   String   @default("[]") // JSON array
  payerBreakdown      String   @default("[]") // JSON array
  recoveryPotential   String   @default("{}") // JSON object
  topDenialReasons    String   @default("[]") // JSON array
  recommendations     String   @default("[]") // JSON array
  contractStatus      String   @default("unsigned") // unsigned, signed, expired
  signedAt            DateTime?
  signedBy            String?
  importedDenialIds   String   @default("[]") // JSON array
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── BATCH PROCESSING ───────────────────────────────────────────────────────────

model BatchJob {
  id            String   @id @default(cuid())
  jobType       String   // analyze, correct, quality_check, appeal_generate
  status        String   @default("pending") // pending, running, completed, failed, cancelled
  totalItems    Int      @default(0)
  processedItems Int     @default(0)
  failedItems   Int      @default(0)
  denialIds     String   @default("[]") // JSON array of denial IDs to process
  results       String   @default("[]") // JSON array of results per item
  errorLog      String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([jobType])
}

// ─── AGENT ORCHESTRATION ────────────────────────────────────────────────────────

model AgentTask {
  id              String   @id @default(cuid())
  agentName       String   // Which agent is handling this
  taskType        String   // analyze, correct, triage, appeal, etc.
  status          String   @default("pending") // pending, running, completed, failed, escalated
  priority        String   @default("normal") // low, normal, high, critical
  denialId        String?
  input           String   @default("{}") // JSON task input
  output          String?  // JSON task output
  parentTaskId    String?  // For sub-tasks spawned by agents
  sourceAgent     String?  // Agent that created this task
  targetAgent     String?  // Agent that should handle this
  toolsUsed       String   @default("[]") // JSON array of tool names used
  confidenceScore Float?
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  denial   Denial?    @relation(fields: [denialId], references: [id])
  parent   AgentTask? @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  children AgentTask[] @relation("TaskHierarchy")

  @@index([agentName])
  @@index([status])
  @@index([denialId])
  @@index([priority])
}

model AgentMemory {
  id          String   @id @default(cuid())
  agentName   String
  memoryType  String   // learning, pattern, preference, rule_update, insight
  key         String   // Lookup key (e.g., "payer:UHC:CO-22:success_rate")
  value       String   // JSON value
  confidence  Float    @default(0.5)
  sourceCount Int      @default(1) // How many observations contributed
  lastUsedAt  DateTime @default(now())
  expiresAt   DateTime? // Optional expiration for time-sensitive data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([agentName, memoryType, key])
  @@index([agentName])
  @@index([memoryType])
  @@index([key])
}

model AgentMessage {
  id          String   @id @default(cuid())
  fromAgent   String
  toAgent     String
  messageType String   // request, response, broadcast, escalation, tool_result
  content     String   // JSON message content
  denialId    String?
  taskId      String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toAgent, isRead])
  @@index([fromAgent])
  @@index([denialId])
}

// ─── PERSISTENT INTELLIGENCE ────────────────────────────────────────────────────

model ResubmissionRecord {
  id                  String   @id @default(cuid())
  denialId            String
  claimNumber         String
  payerName           String
  carcCode            String
  denialCategory      String
  cptCode             String
  deniedAmount        Float
  correctionType      String
  correctionDetails   String
  resubmittedAt       DateTime
  outcome             String   @default("pending") // paid, partially_paid, denied_again, pending, appealed
  paidAmount          Float?
  resolvedAt          DateTime?
  daysToResolution    Int?
  deniedAgainReason   String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([payerName])
  @@index([carcCode])
  @@index([correctionType])
  @@index([outcome])
}

model PayerBehaviorProfile {
  id                    String   @id @default(cuid())
  payerName             String   @unique
  totalSubmissions      Int      @default(0)
  successRate           Float    @default(0.5)
  avgDaysToPayment      Int      @default(30)
  avgRecoveryPercent    Float    @default(0)
  bestCorrectionTypes   String   @default("[]") // JSON
  worstCorrectionTypes  String   @default("[]") // JSON
  topDenialReasons      String   @default("[]") // JSON
  trendData             String   @default("{}") // JSON with lastMonth/last3Months/last6Months/improving
  specialBehaviors      String   @default("{}") // JSON: payer-specific quirks, preferences, portal tips
  lastAnalyzedAt        DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([payerName])
}

// ─── HIPAA COMPLIANCE ───────────────────────────────────────────────────────────

model HIPAAAuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String   // phi_access, phi_export, phi_modify, phi_delete, phi_decrypt, login, logout, baa_event
  entityType      String   // denial, appeal, report, user, system
  entityId        String?
  phiFieldsAccessed String? // JSON array of field names containing PHI
  justification   String?  // Why PHI was accessed
  accessLevel     String   @default("standard") // standard, elevated, emergency
  ipAddress       String?
  userAgent       String?
  sessionId       String?
  result          String   @default("success") // success, denied, error
  denialReason    String?  // If access was denied, why
  metadata        String?  // JSON additional context
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model BAARecord {
  id              String   @id @default(cuid())
  vendorName      String
  baaType         String   // cloud_provider, analytics, ai_service, clearinghouse, storage
  status          String   @default("pending") // pending, active, expired, terminated
  signedDate      DateTime?
  expirationDate  DateTime?
  contactName     String?
  contactEmail    String?
  documentUrl     String?
  phiAccessScope  String   @default("[]") // JSON array of what PHI the vendor can access
  securityMeasures String  @default("[]") // JSON array of required security measures
  breachNotifDays Int      @default(60)  // Days to notify of breach
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vendorName])
  @@index([status])
}

model ComplianceCheck {
  id              String   @id @default(cuid())
  checkType       String   // hipaa_access, phi_encryption, audit_trail, baa_valid, data_retention, phi_minimization
  status          String   @default("pending") // pending, passed, failed, warning
  entityType      String?
  entityId        String?
  findings        String   @default("[]") // JSON array of findings
  remediationSteps String  @default("[]") // JSON array of steps
  checkedBy       String   @default("system") // system, agent name, or user ID
  checkedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([checkType])
  @@index([status])
}

// ─── UNDERPAYMENT DETECTION ─────────────────────────────────────────────────────

model UnderpaymentAlert {
  id              String   @id @default(cuid())
  denialId        String?
  claimNumber     String
  payerName       String
  cptCode         String
  billedAmount    Float
  allowedAmount   Float
  paidAmount      Float
  expectedAmount  Float    // What should have been paid per contract/fee schedule
  underpaidAmount Float
  underpaymentPercent Float
  reasonCode      String?
  status          String   @default("open") // open, investigated, confirmed, disputed, resolved, false_positive
  investigationNotes String?
  resolutionAmount Float?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([payerName])
  @@index([status])
}

// ─── ROOT CAUSE PREVENTION ──────────────────────────────────────────────────────

model PreventionRule {
  id              String   @id @default(cuid())
  ruleName        String
  ruleType        String   // coding_prevention, filing_prevention, auth_prevention, eligibility_prevention
  triggerConditions String @default("{}") // JSON: conditions that trigger this prevention rule
  action          String   @default("warn") // warn, block, auto_correct, escalate
  severity        String   @default("medium")
  sourceAgent     String?  // Which agent created this rule
  sourceInsight   String?  // The insight that led to this rule
  isActive        Boolean  @default(true)
  timesTriggered  Int      @default(0)
  timesPrevented  Int      @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ruleType])
  @@index([isActive])
}

// ─── HUMAN-IN-THE-LOOP ──────────────────────────────────────────────────────────

model HumanApproval {
  id              String   @id @default(cuid())
  taskType        String   // correction_approval, appeal_approval, escalation, high_value_review, compliance_review
  denialId        String?
  agentName       String
  requestedAction String   // JSON description of what agent wants to do
  urgency         String   @default("normal") // low, normal, high, critical
  status          String   @default("pending") // pending, approved, denied, expired, escalated
  reviewedBy      String?
  reviewNotes     String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([urgency])
  @@index([agentName])
}
