# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite for development; use PostgreSQL for production
DATABASE_URL="file:./dev.db"

# ─── THE BRAIN — AI PROVIDERS ─────────────────────────────────────────────────
# The Brain supports multiple AI providers for cross-validation and anti-hallucination:
# 1. Azure OpenAI (GPT-4o) — Primary provider
# 2. Anthropic Claude — Cross-validator / secondary provider
# 3. z-ai-web-dev-sdk — Built-in fallback (no keys needed, always available)
# 4. Rule-based — Zero-hallucination fallback (always available)
#
# The app works WITHOUT any AI keys (falls back to rule-based + z-ai-sdk).
# For best results, configure BOTH Azure OpenAI and Claude for cross-validation.

# Azure OpenAI (Primary — GPT-4o)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic Claude (Cross-validator — Claude 3.5 Sonnet or newer)
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── CROSS-VALIDATION MODE ───────────────────────────────────────────────────
# When both providers are configured, the Brain cross-validates for anti-hallucination.
# Options: 'always' | 'high_stakes' | 'never'
# Default: 'high_stakes' (cross-validates for code generation and corrections)
BRAIN_CROSS_VALIDATION=high_stakes

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# NextAuth configuration (required for production)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-secret-here

# ─── HIPAA COMPLIANCE ────────────────────────────────────────────────────────
# PHI encryption key (32-byte hex string for AES-256). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=your-64-character-hex-encryption-key

# ─── VERCEL DEPLOYMENT ───────────────────────────────────────────────────────
# When deploying to Vercel, set these in Project Settings > Environment Variables
# Switch DATABASE_URL to a persistent PostgreSQL connection string for Vercel
# Example: DATABASE_URL="postgresql://user:password@host:5432/denial_doctor?schema=public"
