# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite for development; use PostgreSQL for production
DATABASE_URL="file:./dev.db"

# ─── AZURE OPENAI (AI Analysis Engine) ───────────────────────────────────────
# Required for AI-powered denial analysis, correction suggestions, and appeal generation.
# The app works without these (falls back to rule-based analysis) but AI features require them.
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# NextAuth configuration (required for production)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-secret-here

# ─── HIPAA COMPLIANCE ────────────────────────────────────────────────────────
# PHI encryption key (32-byte hex string for AES-256). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=your-64-character-hex-encryption-key

# ─── VERCEL DEPLOYMENT ───────────────────────────────────────────────────────
# When deploying to Vercel, set these in Project Settings > Environment Variables
# Switch DATABASE_URL to a persistent PostgreSQL connection string for Vercel
# Example: DATABASE_URL="postgresql://user:password@host:5432/denial_doctor?schema=public"
